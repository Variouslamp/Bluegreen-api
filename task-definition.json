{
  "family": "task-test-bluegreen",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::155700898954:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "contenedor-rust",
      "image": "155700898954.dkr.ecr.us-east-2.amazonaws.com/api-test-bluegreen:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ]
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512"
}
